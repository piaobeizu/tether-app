{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tether",
  "version": "0.1.0-dev",
  "identifier": "ai.tether.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tether",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "tether — pair-coding terminal",
    "longDescription": "tether: agentic pair-coding over WebTransport. Cross-platform via self-written Tauri commands wrapping web-transport-quinn.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "14.0"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["tether"]
      },
      "mobile": [
        {
          "host": "app.tether.ai",
          "pathPrefix": ["/open"]
        }
      ]
    }
  }
}
